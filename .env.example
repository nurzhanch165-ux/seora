# SonyShopKorea — переменные окружения
# Скопируйте в .env.local и заполните значениями из проекта Supabase.

# Публичный URL сайта (кастомный домен на production)
NEXT_PUBLIC_SITE_URL=https://sonyshopkorea.com

# Публичные (доступны в браузере) — из Supabase: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLISHABLE-KEY

# Только сервер (НИКОГДА не коммитить и не отдавать в браузер) — Supabase: Settings → API
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Секрет сессии клиента (httpOnly cookie). Можно использовать CRON_SECRET или отдельный ключ.
CUSTOMER_SESSION_SECRET=

# Логин/пароль администратора — ОБЯЗАТЕЛЬНО смените на production (мин. 12 символов)
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change-me-strong-password

# Опционально: email для MyMemory API (больше лимит перевода товаров)
TRANSLATE_API_EMAIL=

# Секрет для Vercel Cron (ежедневная генерация Excel). Задайте случайную строку.
CRON_SECRET=change-me-to-random-secret

# Доставка внутри Кореи (₩), добавляется к сумме заказа при checkout
NEXT_PUBLIC_DOMESTIC_DELIVERY_KRW=4000

# TikTok магазина (ссылка в уведомлениях о стримах)
NEXT_PUBLIC_TIKTOK_URL=https://www.tiktok.com/@shopkorea8

# Email-уведомления (Resend) — опционально
RESEND_API_KEY=
RESEND_FROM=SonyShopKorea <sonyshopkorea@gmail.com>

# Web Push (VAPID) — опционально, для push на телефон
# Сгенерировать: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:sonyshopkorea@gmail.com

# Telegram-бот для уведомлений о стримах (токен от @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
